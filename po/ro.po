#: src/prefs.ts:29
msgid "Cursor Locator"
msgstr "Localizator Cursor"

#: src/prefs.ts:44
msgid "Keyboard Shortcut"
msgstr "Scurtătură de Tastatură"

#: src/prefs.ts:71
msgid "Animation Duration"
msgstr "Durata Animației"

#: src/prefs.ts:92
msgid "Spotlight Radius"
msgstr "Raza Reflectorului"

#: src/prefs.ts:113
msgid "Enable Jiggle Detection"
msgstr "Activează Detectarea Mișcării"

#: src/prefs.ts:114
msgid "Automatically show the locator when the mouse is jiggled."
msgstr "Afișează automat localizatorul când mouse-ul este mișcat rapid."

#: src/prefs.ts:129
msgid "Reset Settings"
msgstr "Resetează Setările"

#: src/prefs.ts:130
msgid ""
"Restore shortcut, animation duration, spotlight radius, and jiggle detection."
msgstr ""
"Restabilește scurtătura, durata animației, raza reflectorului și detectarea "
"mișcării."

#: src/prefs.ts:134
msgid "Reset"
msgstr "Resetează"

#: src/prefs.ts:156
msgid "Press a new shortcut, Backspace to disable, or Escape to cancel."
msgstr ""
"Apăsați o nouă scurtătură, Backspace pentru dezactivare sau Escape pentru "
"anulare."
